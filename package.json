    "db:sync": "node scripts/db-sync.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "ws": "^8.21.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "ssh2": "^1.17.0"
  }
}
