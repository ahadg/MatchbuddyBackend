{
  "name": "matchbuddy-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "import:world-cup-2026": "node src/scripts/import-world-cup-2026.js",
    "db:up": "docker compose up -d",
