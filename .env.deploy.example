# SSH Connection Settings for VPS
DEPLOY_HOST=your_vps_ip_here
DEPLOY_PORT=22
DEPLOY_USER=root

# Provide either DEPLOY_PASSWORD or DEPLOY_KEY_PATH (relative to workspace or absolute)
DEPLOY_PASSWORD=your_ssh_password_here
# DEPLOY_KEY_PATH=~/.ssh/id_rsa

# Repository and Deployment Directory on the VPS
DEPLOY_PATH=/var/www/matchbuddy-backend
DEPLOY_REPO=https://github.com/ahadg/MatchbuddyBackend.git
DEPLOY_BRANCH=main

# Nginx Server Configuration (Domain or IP)
DEPLOY_DOMAIN=api.matchbuddy.shop

# Docker setup on VPS (Optional, set container name if PostgreSQL runs in Docker on server)
REMOTE_DB_CONTAINER=matchbuddy-postgis

# -------------------------------------------------------------
# PRODUCTION ENVIRONMENT VARIABLES (Written to VPS .env)
# -------------------------------------------------------------
PROD_PORT=4000
PROD_CLIENT_ORIGIN=https://matchbuddy.shop
PROD_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/matchbuddy
PROD_SUPABASE_URL=https://your-project.supabase.co
PROD_SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
PROD_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
PROD_RESEND_FROM_EMAIL=noreply@matchbuddy.shop
PROD_RESEND_FROM_NAME=MatchBuddy
PROD_ONESIGNAL_APP_ID=c6f336ef-6a2***
PROD_ONESIGNAL_REST_API_KEY=os_v2_app_xxxxxxxxxxxxxxxxxxxx
ADMIN_EMAILS=muhmmadahad594@gmail.com
